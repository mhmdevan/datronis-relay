# datronis-relay — secrets and runtime overrides.
#
# Non-secret configuration lives in config.yaml (see config.example.yaml).
# This file holds only the values that must not be committed to version
# control. Docker Compose reads it automatically; systemd reads it via the
# EnvironmentFile= directive in the unit.
#
# ============================================================================
# AUTHENTICATION WITH CLAUDE
# ============================================================================
# datronis-relay uses the `claude-agent-sdk`, which inherits authentication
# from the Claude Code CLI. You have two options — pick ONE, leave the other
# blank:
#
#   1) RECOMMENDED — Claude.ai subscription (Pro / Max / Teams / Enterprise)
#
#      Run `claude login` once on the host where the bot will run. Claude
#      Code opens a browser (or prints a device code on headless hosts); you
#      authenticate with your Claude.ai account; credentials are saved to
#      $HOME/.claude/ and picked up automatically by the SDK.
#
#      With this path, LEAVE `ANTHROPIC_API_KEY` BLANK. You do not need it.
#      Cost is covered by your subscription — no per-token billing.
#
#   2) ALTERNATIVE — pay-per-token API key
#
#      Set `ANTHROPIC_API_KEY` below. The SDK will use it instead of the
#      OAuth credentials. Billed per-token via the Anthropic Console. Use
#      this only if you don't already pay for a Claude subscription.
#
# If both are set, the Claude Code CLI / SDK uses the precedence rule
# documented upstream (currently: the API key takes precedence when
# present). You almost never want both — pick one.
# ============================================================================

# --- Telegram (required) ---
# Get from @BotFather. https://t.me/BotFather
DATRONIS_TELEGRAM_BOT_TOKEN=

# --- Claude auth (optional — leave blank if you ran `claude login`) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Slack (optional — setting either of these also enables the Slack adapter) ---
# DATRONIS_SLACK_BOT_TOKEN=xoxb-...
# DATRONIS_SLACK_APP_TOKEN=xapp-...

# --- Runtime overrides (optional) ---
# DATRONIS_CONFIG_PATH=./config.yaml
# DATRONIS_LOG_LEVEL=INFO
# DATRONIS_LOG_JSON=true
