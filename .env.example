# Phase 2 keeps only secrets and a handful of overrides in env vars. The
# rest of the configuration lives in config.yaml (see config.example.yaml).

# --- Secrets ---
# Overrides telegram.bot_token in config.yaml:
DATRONIS_TELEGRAM_BOT_TOKEN=

# Read directly by the Claude Agent SDK itself:
ANTHROPIC_API_KEY=

# --- Optional overrides ---
# Alternate path to the YAML config file (default: ./config.yaml)
# DATRONIS_CONFIG_PATH=./config.yaml

# Override logging at runtime without editing YAML:
# DATRONIS_LOG_LEVEL=INFO
# DATRONIS_LOG_JSON=true
